MEET_DOMAIN=meet.omni.elvismao.com
PUBLIC_URL=https://meet.omni.elvismao.com
TZ=Asia/Taipei
JITSI_IMAGE_VERSION=stable-10888
RESTART_POLICY=unless-stopped

# Dokploy normally creates this external network for Traefik.
DOKPLOY_NETWORK=dokploy-network

# Traefik/Dokploy terminates HTTPS. Jitsi web serves plain HTTP internally.
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0
ENABLE_LETSENCRYPT=0

# Open meeting rooms. Change these if you want authenticated hosts later.
ENABLE_AUTH=0
ENABLE_GUESTS=1
AUTH_TYPE=internal

# Current public media address for meet.omni.elvismao.com.
# Update this if the machine public IP changes.
JVB_ADVERTISE_IPS=203.145.220.54
JVB_PORT=10000
JVB_COLIBRI_PORT=8080
COLIBRI_REST_ENABLED=1
ENABLE_COLIBRI_WEBSOCKET=0
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=change-me
JICOFO_AUTH_PASSWORD=change-me
JVB_BREWERY_MUC=jvbbrewery

ENABLE_XMPP_WEBSOCKET=1
ENABLE_P2P=1
ENABLE_PREJOIN_PAGE=1
ENABLE_WELCOME_PAGE=1
JVB_PREFER_SCTP=1

RESOLUTION=720
RESOLUTION_WIDTH=1280
START_AUDIO_MUTED=10
START_VIDEO_MUTED=10

XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
XMPP_SERVER=xmpp.meet.jitsi
XMPP_PORT=5222

# Unused unless Jigasi/Jibri recording/transcription is enabled later.
JIGASI_XMPP_PASSWORD=
JIGASI_TRANSCRIBER_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
